generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  avatarUrl     String?
  passwordHash  String
  role          Role           @default(STUDENT)
  createdAt     DateTime       @default(now())
  channels      Channel[]
  comments      Comment[]
  notifications Notification[]
}

enum Role {
  ADMIN
  STUDENT
}

model Channel {
  id               String         @id @default(cuid())
  youtubeChannelId String         @unique
  name             String
  handle           String?
  avatarUrl        String?
  subscriberCount  Int            @default(0)
  viewCount        Int            @default(0)
  videoCount       Int            @default(0)
  uploadPlaylistId String?
  lastSync         DateTime?
  channelIdea      String?
  studentId        String
  student          User           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())
  videos           Video[]
  comments         Comment[]
  notifications    Notification[] @relation("ChannelNotifications")
}

model Video {
  id              String    @id @default(cuid())
  youtubeVideoId  String    @unique
  channelId       String
  channel         Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  title           String
  thumbnailUrl    String?
  views           Int       @default(0)
  likes           Int       @default(0)
  commentsCount   Int       @default(0)
  durationSeconds Int       @default(0)
  isShort         Boolean   @default(false)
  publishedAt     DateTime?
  outlierScore    Float     @default(0)
  videoIdea       String?
  videoLinks      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  comments        Comment[]
}

model Comment {
  id            String         @id @default(cuid())
  channelId     String
  channel       Channel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
  videoId       String?
  video         Video?         @relation(fields: [videoId], references: [id])
  authorId      String
  author        User           @relation(fields: [authorId], references: [id])
  type          CommentType
  content       String
  createdAt     DateTime       @default(now())
  notifications Notification[]
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(FEEDBACK)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  // FEEDBACK notifications
  commentId String?
  comment   Comment?         @relation(fields: [commentId], references: [id], onDelete: Cascade)
  // NEW_CHANNEL notifications
  channelId String?
  channel   Channel?         @relation("ChannelNotifications", fields: [channelId], references: [id], onDelete: Cascade)
}

enum NotificationType {
  FEEDBACK
  NEW_CHANNEL
}

enum CommentType {
  FEEDBACK
  DIRECIONAMENTO
  OBSERVACAO
}
